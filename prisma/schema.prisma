generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id        String   @id @default(uuid())
  name      String
  badgeId   Int      @unique
  sectorId  String
  sector    Sector   @relation(fields: [sectorId], references: [id])
  jobTitle  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sector {
  id         String     @id @default(uuid())
  name       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employeers Employee[]
}
