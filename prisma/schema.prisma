generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Employee {
  id        String   @id @default(uuid())
  name      String
  badgeId   Int      @unique
  sectorId  String
  sector    Sector   @relation(fields: [sectorId], references: [id])
  jobTitle  String
  isActive  Boolean  @default(true)
  createdAt DateTime
  updatedAt DateTime
}

model Sector {
  id         String     @id @default(uuid())
  name       String
  createdAt  DateTime
  updatedAt  DateTime
  employeers Employee[]
}
